{
  "name": "@team-memory/server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev":        "tsx watch --env-file=../../.env src/index.ts",
    "dev:http":   "MCP_TRANSPORT=http tsx watch --env-file=../../.env src/index.ts",
    "build":      "tsc",
    "start":      "node --env-file=../../.env dist/index.js",
    "start:http": "MCP_TRANSPORT=http node --env-file=../../.env dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "express": "^4.19.2",
    "pg": "^8.13.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.17",
    "@types/pg": "^8.11.13",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
