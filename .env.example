# ── Base de datos ──────────────────────────────────────────────────────────────
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_HOST=
DB_PORT=

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_URL=
OLLAMA_EMBED_MODEL=
OLLAMA_CHAT_MODEL=

# ── MCP Server ─────────────────────────────────────────────────────────────────
MCP_SERVER_NAME=

# Transporte: 'stdio' (local/dev) | 'http' (servidor interno/VPN — Streamable HTTP)
MCP_TRANSPORT=

# Puerto del servidor HTTP — solo relevante cuando MCP_TRANSPORT=http
MCP_PORT=3100

# ── Scripts de test con IA (opcional) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
