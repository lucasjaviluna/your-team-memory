{
  "name": "team-memory",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "team-memory",
      "version": "1.0.0",
      "workspaces": [
        "packages/installer"
      ],
      "bin": {
        "team-memory": "packages/installer/cli.mjs"
      }
    },
    "node_modules/@team-memory/installer": {
      "resolved": "packages/installer",
      "link": true
    },
    "packages/installer": {
      "name": "@team-memory/installer",
      "version": "1.0.0",
      "engines": {
        "node": ">=22"
      }
    },
    "packages/server": {
      "name": "@team-memory/server",
      "version": "1.0.0",
      "extraneous": true,
      "dependencies": {
        "@anthropic-ai/sdk": "^0.39.0",
        "@modelcontextprotocol/sdk": "^1.10.2",
        "express": "^4.19.2",
        "pg": "^8.13.3",
        "zod": "^3.24.4"
      },
      "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^22.15.17",
        "@types/pg": "^8.11.13",
        "tsx": "^4.19.3",
        "typescript": "^5.8.3"
      }
    }
  }
}
